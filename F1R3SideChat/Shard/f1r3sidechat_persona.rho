// ============================================================
// F1R3SideChat AI Persona Contract
// f1r3sidechat_persona.rho
//
// Authors configure named AI personas per story. Each persona
// has a personality spec (content hash) and is referenced by
// the core contract when attributing AI-authored beats.
//
// The AI itself runs off-chain (Claude API); this contract
// records the persona definition and tracks its beat history.
// ============================================================

new
  personaRegistry,
  _insertPersona,
  _lookupPersona,
  personaMap,
  registryInsert(`rho:registry:insertArbitrary`),
  stdout(`rho:io:stdout`)
in {

  // PersonaRecord = {
  //   id:           String,
  //   name:         String,       // display name, e.g. "Cassiel"
  //   ownerPub:     String,       // story author's pubkey
  //   storyId:      String,       // scoped to a specific story (or "*" for platform persona)
  //   specHash:     String,       // SHA-256 of the persona spec document (off-chain)
  //   specSummary:  String,       // short on-chain description
  //   model:        String,       // AI model identifier
  //   beatCount:    Int,
  //   createdAt:    Int
  // }

  contract personaRegistry(@"create", @personaId, @name, @ownerPub, @storyId,
                             @specHash, @specSummary, @model, ack) = {
    new existingCh in {
      _lookupPersona!(personaId, *existingCh) |
      for (@existing <- existingCh) {
        match existing {
          Nil => {
            new pRec in {
              @pRec!({
                "id":          personaId,
                "name":        name,
                "ownerPub":    ownerPub,
                "storyId":     storyId,
                "specHash":    specHash,
                "specSummary": specSummary,
                "model":       model,
                "beatCount":   0,
                "createdAt":   0
              }) |
              _insertPersona!(personaId, *pRec) |
              ack!("ok")
            }
          }
          _ => { ack!("error:persona_exists") }
        }
      }
    }
  } |

  contract personaRegistry(@"get", @personaId, ack) = {
    _lookupPersona!(personaId, *ack)
  } |

  contract personaRegistry(@"incrementBeatCount", @personaId, ack) = {
    new pCh in {
      _lookupPersona!(personaId, *pCh) |
      for (@p <- pCh) {
        match p {
          Nil  => { ack!("error:not_found") }
          rec  => {
            _insertPersona!(personaId, rec.set("beatCount", rec.get("beatCount") + 1)) |
            ack!("ok")
          }
        }
      }
    }
  } |

  contract personaRegistry(@"updateSpec", @personaId, @newSpecHash, @newSpecSummary, @callerPub, ack) = {
    new pCh in {
      _lookupPersona!(personaId, *pCh) |
      for (@p <- pCh) {
        match p {
          Nil => { ack!("error:not_found") }
          rec => {
            match rec.get("ownerPub") == callerPub {
              true  => {
                _insertPersona!(personaId, rec.set("specHash", newSpecHash).set("specSummary", newSpecSummary)) |
                ack!("ok")
              }
              false => { ack!("error:not_owner") }
            }
          }
        }
      }
    }
  } |

  // Backing store
  contract _insertPersona(@key, val) = { @(*personaMap, key)!(val) } |
  contract _lookupPersona(@key, ack) = {
    for (@v <<- @(*personaMap, key)) { ack!(v) }
  } |

  registryInsert!(bundle+{*personaRegistry}, "rho:id:f1r3sidechat:personaRegistry") |
  stdout!("F1R3SideChat Persona Contract deployed.")
}
